# --- Serveur ---
PORT=4000

# --- Base de données MongoDB ---
# Local : mongodb://127.0.0.1:27017/avenir_crazy_dance
# Atlas : mongodb+srv://adriennew:adrientest@cluster.xxxx.mongodb.net/avenir_crazy_dance
MONGODB_URI=mongodb+srv://adriennew:adrientest@cluster0.yhvwi.mongodb.net/avenircrazydance?retryWrites=true&w=majority

# --- Authentification admin ---
# Secret utilisé pour signer les jetons JWT (mettez une longue chaîne aléatoire)
JWT_SECRET=changez-moi-pour-un-secret-long-et-aleatoire
# Identifiants du compte administrateur initial créé au démarrage
ADMIN_EMAIL=admin@avenircrazydance.be
ADMIN_PASSWORD=admin123

# URL publique du serveur (utile pour construire les URLs d'images)
PUBLIC_URL=http://localhost:4000

# --- CORS : domaine(s) du frontend autorisés à appeler l'API ---
# Laisser vide en dev = autoriser toutes les origines.
# En production (frontend OVH) : indiquer le(s) domaine(s), séparés par des virgules.
# Ex : FRONTEND_URL=https://www.avenircrazydance.be,https://avenircrazydance.be
FRONTEND_URL=

# --- Stockage des uploads ---
# Local : laisser vide (utilise ./server/uploads)
# Railway : pointer vers le point de montage du Volume, ex: /data/uploads
UPLOAD_DIR=

# --- Formulaire de contact ---
# >>> Adresse de la DIRECTION qui reçoit les messages du formulaire de contact <<<
CONTACT_EMAIL=direction@avenircrazydance.be
# Paramètres SMTP utilisés pour expédier les e-mails (ex: Gmail, OVH, Mailgun…)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Expéditeur affiché dans l'e-mail reçu par la direction
SMTP_FROM="Site Avenir Crazy Dance <no-reply@avenircrazydance.be>"

